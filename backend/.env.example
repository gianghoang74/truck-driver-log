# Copy to backend/.env and fill in. All values have safe local defaults except ORS_API_KEY.

# Django
SECRET_KEY=dev-insecure-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS — the frontend origin(s)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# OpenRouteService — get a free key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=
ORS_BASE_URL=https://api.openrouteservice.org

# Cache TTL for geocode/route lookups, in seconds (default 24h).
# ROUTING_CACHE_SECONDS=86400

# Rate limits (optional; defaults shown). "plan"/"geocode" are per-IP;
# "global_ors" is one shared bucket across all clients, kept below ORS's
# per-minute limit so we return 429 before ORS starts erroring.
# THROTTLE_PLAN=20/min
# THROTTLE_GEOCODE=60/min
# THROTTLE_GLOBAL_ORS=40/min
